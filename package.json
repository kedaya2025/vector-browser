{
  "name": "vector-browser",
  "version": "1.0.0",
  "description": "Vector Browser - Browser environment management tool",
  "main": "electron/main.js",
  "author": "",
  "scripts": {
    "dev": "vue-cli-service serve",
    "lint": "eslint --ext .js,.vue src",
    "build": "vue-cli-service build",
    "build:stage": "vue-cli-service build --mode staging",
    "preview": "node build/index.js --preview",
    "new": "plop",
    "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml",
    "kill:running-apps": "node scripts/kill-running-apps.js",
    "electron:dev": "concurrently \"vue-cli-service serve\" \"wait-on http://localhost:9527 && electron .\"",
    "electron:build": "npm run kill:running-apps && npm run build && electron-builder --dir",
    "fix:icons": "node scripts/fix-icons.js",
    "dist": "npm run kill:running-apps && npm run build && electron-builder --win nsis && node scripts/fix-icons.js"
  },
  "build": {
    "appId": "com.vectorbrowser.app",
    "productName": "Vector Browser",
    "asar": true,
    "asarUnpack": [
      "static/**/*"
    ],
    "directories": {
      "output": "build",
      "buildResources": "build"
    },
    "files": [
      "package.json",
      "dist/**/*",
      "electron/**/*",
      "static/**/*"
    ],
    "extraResources": [
      {
        "from": "static/logo.ico",
        "to": "logo.ico"
      }
    ],
    "afterPack": "./scripts/after-pack.js",
    "win": {
      "icon": "static/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vector Browser",
      "installerIcon": "static/logo.ico",
      "uninstallerIcon": "static/logo.ico",
      "installerHeaderIcon": "static/logo.ico"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.3.4",
    "clipboard": "^2.0.11",
    "compare-versions": "^6.1.0",
    "core-js": "3.6.5",
    "element-ui": "2.13.2",
    "file-saver": "^2.0.5",
    "fuse.js": "3.4.4",
    "js-cookie": "^3.0.1",
    "normalize.css": "7.0.0",
    "nprogress": "^0.2.0",
    "path-to-regexp": "^6.2.1",
    "pinyin": "^2.11.2",
    "random": "^4.1.0",
    "screenfull": "^4.2.1",
    "uuid": "^9.0.0",
    "v-clipboard": "^3.0.0-next.1",
    "vue": "2.6.10",
    "vue-i18n": "7.3.2",
    "vue-router": "3.0.2",
    "vuex": "3.1.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "4.4.4",
    "@vue/cli-plugin-eslint": "4.4.4",
    "@vue/cli-service": "4.4.4",
    "autoprefixer": "9.5.1",
    "babel-eslint": "10.1.0",
    "babel-plugin-dynamic-import-node": "2.3.3",
    "chalk": "2.4.2",
    "chokidar": "2.1.5",
    "concurrently": "^8.2.2",
    "connect": "3.6.6",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^8.0.3",
    "html-webpack-plugin": "3.2.0",
    "husky": "1.3.1",
    "lint-staged": "8.1.5",
    "mockjs": "1.0.1-beta3",
    "plop": "2.3.0",
    "prettier": "^2.8.8",
    "rcedit": "^5.0.2",
    "runjs": "4.3.2",
    "sass": "1.26.2",
    "sass-loader": "8.0.2",
    "script-ext-html-webpack-plugin": "2.1.3",
    "serve-static": "1.13.2",
    "svg-sprite-loader": "4.1.3",
    "svgo": "1.2.0",
    "vue-template-compiler": "2.6.10",
    "wait-on": "^7.2.0"
  },
  "browserslist": [
    "chrome > 100"
  ],
  "engines": {
    "node": ">=8.9",
    "npm": ">= 3.0.0"
  },
  "keywords": [
    "vue",
    "admin",
    "dashboard",
    "element-ui",
    "boilerplate",
    "admin-template",
    "management-system"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{js,vue}": [
      "eslint --fix",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PanJiaChen/vue-element-admin.git"
  }
}
